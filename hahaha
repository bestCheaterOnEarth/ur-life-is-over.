                            Cheat.value = val
                            local ratio = math.clamp((val.Slider - minV) / (maxV - minV), 0, 1)
                            sliderValue.Text = string.format("%." .. rounding .. "f", val.Slider)
                            fill.Size = UDim2.new(ratio, 0, 1, 0)
                            callback(val)
                        end
                    
