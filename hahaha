    function Menu:Tab(tabName)
        local Tab = {}

        local tabButton = tabButtonTemplate:Clone()
        local tabPage   = tabPageTemplate:Clone()

        tabPage.Fix.ClipsDescendants = true
        tabPage.Name  = tabName
        tabButton.Visible = true
        tabButton.Name    = tabName
        tabButton.TextLabel.Text = tabName

        if firstTab then
            tabPage.Visible   = true
            firstTab          = false
            activeTabName     = tabName
        else
            tabButton.Frame.BackgroundTransparency = 1
            tabButton.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
        end

        tabButton.MouseButton1Down:Connect(function()
            activeTabName = tabName
            tabPage.Visible = true

            Library:Tween(tabButton.Frame, TWEEN_MED, { BackgroundTransparency = 0 })
            Library:Tween(tabButton, TWEEN_MED, { BackgroundColor3 = Color3.fromRGB(23, 23, 23) })

            for _, btn in pairs(tabButtonsFrame:GetChildren()) do
                if btn:IsA("TextButton") and btn.Name ~= activeTabName then
                    Library:Tween(btn.Frame, TWEEN_MED, { BackgroundTransparency = 1 })
                    Library:Tween(btn, TWEEN_MED, { BackgroundColor3 = Color3.fromRGB(15, 15, 15) })
                end
            end

            for _, page in pairs(tabsContainer:GetChildren()) do
                if page:IsA("Frame") and page.Name ~= activeTabName then
                    page.Visible = false
                end
            end
        end)

        -- ── Inner tabs ───────────────────────────────────────

        local firstInnerTab = true
        local activeInnerTab = nil
        local innerTabCount  = 0

        function Tab:Tab(innerName)
            local InnerTab = {}

            innerTabCount = innerTabCount + 1

            local innerBtn = innerTabTemplate:Clone()
            innerBtn.Text    = innerName
            innerBtn.Name    = innerName
            innerBtn.Visible = true

            if firstInnerTab then
                firstInnerTab = false
                activeInnerTab = innerName
            else
                innerBtn.Decoration.BackgroundTransparency = 1
                innerBtn.Frame.Visible = false
            end

            innerBtn.Frame.Name = innerName

            innerBtn.MouseButton1Down:Connect(function()
                activeInnerTab = innerName
                tabPage.Fix[innerName].Visible = true

                Library:Tween(innerBtn.Decoration, TWEEN_MED, { BackgroundTransparency = 0 })

                for _, btn in pairs(tabPage.Frame:GetChildren()) do
                    if btn:IsA("TextButton") and btn.Name ~= innerName then
                        Library:Tween(btn.Decoration, TWEEN_MED, { BackgroundTransparency = 1 })
                        tabPage.Fix[btn.Name].Visible = false
                    end
                end
            end)

            innerBtn[innerName].Parent = tabPage.Fix
            innerBtn.Parent            = tabPage.Frame

            -- Redimensionar todos os botões igualmente
            for _, btn in pairs(tabPage.Frame:GetChildren()) do
                if btn:IsA("TextButton") then
                    btn.Size = UDim2.new(1 / innerTabCount, 0, 1, 0)
                end
            end

            -- ── Section criação ──────────────────────────────

            function InnerTab:Section(sectionName, columnSide)
                local Section = {}

                local sectionFrame = Instance.new("Frame")
                sectionFrame.Name             = "Section"
                sectionFrame.Parent           = tabPage.Fix[innerBtn.Text][columnSide]
                sectionFrame.BackgroundColor3 = BG_PANEL
                sectionFrame.BorderSizePixel  = 0
                sectionFrame.Size             = UDim2.new(1, 0, 0, 18)

                local sectionBorder = Instance.new("Frame")
                sectionBorder.Parent           = sectionFrame
                sectionBorder.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
                sectionBorder.BorderSizePixel  = 0
                sectionBorder.Position         = UDim2.new(0, 1, 0, 1)
