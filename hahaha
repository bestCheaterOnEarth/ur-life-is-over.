                                Library:Tween(lbl, TWEEN_FAST, { TextColor3 = TEXT_OFF })
                            end

                            resetTypeColors()
                            if val.Type == "Always" then
                                btnAlways.TextColor3 = ACCENT
                                btnAlways.Font       = Enum.Font.SourceSansBold
                            elseif val.Type == "Hold" then
                                btnHold.TextColor3 = ACCENT
                                btnHold.Font       = Enum.Font.SourceSansBold
                            elseif val.Type == "Toggle" then
                                btnToggle.TextColor3 = ACCENT
                                btnToggle.Font       = Enum.Font.SourceSansBold
                            end

                            Cheat.value.Active = val.Type == "Always"

                            keybindBtn.Text = val.Key ~= nil and "[" .. val.Key .. "]" or "[None]"
                            callback(val)
                        end

                        game:GetService("UserInputService").InputBegan:Connect(function(input)
                            -- Fechar dropdown ao clicar fora
                            if (input.UserInputType == Enum.UserInputType.MouseButton1 or
                                input.UserInputType == Enum.UserInputType.MouseButton2) and not listeningForKey then
                                if typeDropdown.Visible and not dropdownHover and not keybindHover then
                                    typeDropdown.Visible = false
                                end
                            end

                            -- Capturar tecla
                            if listeningForKey then
                                listeningForKey = false
                                local keyName = input.KeyCode.Name ~= "Unknown"
                                    and input.KeyCode.Name
                                    or  input.UserInputType.Name

                                if input.KeyCode.Name == "Backspace" then
                                    keybindBtn.Text    = "[None]"
                                    Cheat.value.Key    = nil
                                else
                                    keybindBtn.Text    = "[" .. keyName .. "]"
                                    Cheat.value.Key    = keyName
                                end
                            end

                            -- Toggle por tecla
                            if Cheat.value.Key ~= nil and Cheat.value.Type == "Toggle" then
                                local matchKey   = input.KeyCode.Name        == Cheat.value.Key
                                local matchMouse = input.UserInputType.Name  == Cheat.value.Key
                                if matchKey or matchMouse then
                                    Cheat.value.Active = not Cheat.value.Active
                                end
                            end
                        end)

                        outerBtn.MouseButton1Down:Connect(function()
                            Cheat.value.Toggle = not Cheat.value.Toggle
                            Cheat:SetValue(Cheat.value)
                        end)

                        if options.default ~= nil then
                            Cheat:SetValue(options.default)
                        end

                    -- ── ToggleColor ───────────────────────────
                    elseif cheatType == "ToggleColor" then
                        sectionFrame.Size = sectionFrame.Size + UDim2.new(0, 0, 0, 16)

                        local btn = Instance.new("TextButton")
                        btn.Name               = "Toggle"
                        btn.Parent             = sectionInner
                        btn.BackgroundTransparency = 1
                        btn.Modal              = true
                        btn.Size               = UDim2.new(1, 0, 0, 14)
                        btn.Font               = Enum.Font.SourceSans
                        btn.Text               = ""

                        local box = Instance.new("Frame")
