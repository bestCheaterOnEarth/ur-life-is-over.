                        box.Position         = UDim2.new(0, 8, 0, 0)
                        box.Size             = UDim2.new(0, 10, 0, 10)

                        local lbl = Instance.new("TextLabel")
                        lbl.Parent               = btn
                        lbl.BackgroundTransparency = 1
                        lbl.Position             = UDim2.new(0.127, 0, 0, -1)
                        lbl.Size                 = UDim2.new(0.873, 0, 1, -4)
