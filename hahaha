                                local mouseX = math.clamp(mx.X - track.AbsolutePosition.X, 0, 162)
                                local ratio = mouseX / 162
                                
                                -- Cálculo com arredondamento dinâmico
                                local rawValue = minV + (maxV - minV) * ratio
                                local power = 10 ^ rounding
                                local v = math.floor(rawValue * power + 0.5) / power
                                
                                fill.Size = UDim2.new(ratio, 0, 1, 0)
                                sliderValue.Text = string.format("%." .. rounding .. "f", v)
                                Cheat.value.Slider = v
                                callback(Cheat.value)
                            end
                    
                            update()
                            local move = mx.Move:Connect(update)
                            local rel
                            rel = UIS.InputEnded:Connect(function(inp)
