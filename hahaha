                            local mx = game:GetService("Players").LocalPlayer:GetMouse()
                            local px = math.clamp(mx.X - satValPicker.AbsolutePosition.X, 0, 152)
                            local py = math.clamp(mx.Y - satValPicker.AbsolutePosition.Y, 0, 152)
