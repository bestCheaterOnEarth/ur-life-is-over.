                            if Cheat.value.Toggle then
                                if Cheat.value.Type == "Always" then
                                    Menu.Keylist:Add(options.listname)
                                    -- Atualiza o status para "Always"
                                    local row = keyList:FindFirstChild(options.listname)
                                    if row then
                                        -- Encontra o segundo TextLabel (status)
                                        for _, child in pairs(row:GetChildren()) do
                                            if child:IsA("TextLabel") and child ~= row.KeyText then
                                                child.Text = "(Always)"
                                            end
                                        end
                                    end
                                elseif Cheat.value.Active and Cheat.value.Key ~= nil then
                                    Menu.Keylist:Add(options.listname)
